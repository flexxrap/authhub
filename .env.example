# Copy to .env and adjust as needed. .env is gitignored - never commit it.

DATABASE_URL=postgresql+asyncpg://authhub:authhub@postgres:5432/authhub

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# used by the postgres container itself
POSTGRES_USER=authhub
POSTGRES_PASSWORD=authhub
POSTGRES_DB=authhub
